{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "currency": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "bn"] },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "incomes": {
      "title": "Income",
      "description": "Income records",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "source": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "category", "date", "userId"]
    },
    "expenses": {
      "title": "Expense",
      "description": "Expense records",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "purpose": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "category", "date", "userId"]
    },
    "banks": {
      "title": "Bank Account",
      "description": "Bank account details and transactions",
      "type": "object",
      "properties": {
        "bankName": { "type": "string" },
        "accountName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "branchName": { "type": "string" },
        "currentBalance": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bankName", "accountName", "userId"]
    },
    "bankTransactions": {
      "title": "Bank Transaction",
      "description": "Bank deposit and withdrawal records",
      "type": "object",
      "properties": {
        "bankId": { "type": "string" },
        "bankName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["Deposit", "Withdrawal"] },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bankId", "amount", "type", "date", "userId"]
    },
    "loans": {
      "title": "Loan",
      "description": "Loan given or taken",
      "type": "object",
      "properties": {
        "personName": { "type": "string" },
        "personId": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "type": { "type": "string", "enum": ["given", "taken"] },
        "principalAmount": { "type": "number" },
        "profitAmount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "installmentAmount": { "type": "number" },
        "totalInstallments": { "type": "number" },
        "paidInstallments": { "type": "number" },
        "paidAmount": { "type": "number" },
        "remainingDue": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "paid", "settled"] },
        "notes": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["personName", "type", "principalAmount", "userId"]
    },
    "customers": {
      "title": "Customer",
      "description": "Customer/Person contact info",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "type": { "type": "string", "enum": ["customer", "borrower", "lender"] },
        "notes": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "userId"]
    },
    "creditTransactions": {
      "title": "Credit Transaction",
      "description": "Credit sales and purchases (Baki)",
      "type": "object",
      "properties": {
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "totalPrice": { "type": "number" },
        "paidAmount": { "type": "number" },
        "dueAmount": { "type": "number" },
        "customerName": { "type": "string" },
        "customerId": { "type": "string" },
        "type": { "type": "string", "enum": ["sale", "purchase"] },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productName", "totalPrice", "userId"]
    },
    "categories": {
      "title": "Category",
      "description": "Income/Expense categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "userId"]
    },
    "cashAccounts": {
      "title": "Cash Account",
      "description": "Cash balance for the user",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["balance", "userId"]
    },
    "onlineAccounts": {
      "title": "Online Account",
      "description": "BKash, Nagad, etc. accounts",
      "type": "object",
      "properties": {
        "platform": { "type": "string" },
        "accountName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["platform", "userId"]
    },
    "persons": {
      "title": "Person",
      "description": "Person registry for loans",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "fathersName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "address": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "userId"]
    },
    "onlineTransactions": {
      "title": "Online Transaction",
      "description": "Transactions on online accounts",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "platform": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "note": { "type": "string" },
        "accountId": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "bankId": { "type": "string" },
        "methodAccountId": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["amount", "platform", "userId"]
    }
  },
  "firestore": {
    "users": { "schema": "users", "description": "User profiles" },
    "incomes": { "schema": "incomes", "description": "User income records" },
    "expenses": { "schema": "expenses", "description": "User expense records" },
    "banks": { "schema": "banks", "description": "User bank accounts" },
    "loans": { "schema": "loans", "description": "User loan records" },
    "customers": { "schema": "customers", "description": "User contacts/customers" },
    "creditTransactions": { "schema": "creditTransactions", "description": "User credit transactions" },
    "categories": { "schema": "categories", "description": "Income/Expense categories" },
    "cashAccounts": { "schema": "cashAccounts", "description": "User cash balances" },
    "onlineAccounts": { "schema": "onlineAccounts", "description": "User online payment accounts" },
    "bankTransactions": { "schema": "bankTransactions", "description": "User bank transaction records" },
    "persons": { "schema": "persons", "description": "Person loan logs" },
    "onlineTransactions": { "schema": "onlineTransactions", "description": "Online transaction history" }
  }
}
